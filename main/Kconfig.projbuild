menu "ATL200"

    config ATL_LED_GPIO
        int "LED GPIO number"
        range 0 48
        default 8
        help
            GPIO number (IOxx) to blink on and off the LED.
    
    config ATL_LED_PERIOD
        int "LED blink period (in ms)"
        range 100 3600000
        default 2000
        help
            Define the blinking period (in milliseconds).

endmenu
